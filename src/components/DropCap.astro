---
// Wrapper to mark the first paragraph of a post for the drop-cap treatment.
// Usage: <DropCap><p>Body opens here…</p></DropCap>
---

<div class="drop-cap">
  <slot />
</div>

<style>
  .drop-cap :global(p:first-of-type)::first-letter {
    font-family: var(--font-display);
    font-variation-settings: 'SOFT' 100, 'opsz' 144;
    font-weight: 600;
    font-size: 5.5em;
    float: left;
    line-height: 0.85;
    margin: 0.05em 0.08em 0 -0.04em;
    color: var(--blood);
  }
</style>
