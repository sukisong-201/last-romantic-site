---
interface Props {
  variant?: 'inline' | 'card';
  heading?: string;
  lede?: string;
}
const {
  variant = 'card',
  heading = 'Subscribe.',
  lede,
} = Astro.props;
---

<aside class:list={['subscribe', `subscribe--${variant}`]}>
  <p class="kicker">The dispatch</p>
  <h3 class="subscribe__title">{heading}</h3>
  {lede && <p class="subscribe__lede">{lede}</p>}
  <iframe
    src="https://champagnesuki.substack.com/embed"
    width="100%"
    height="120"
    title="Subscribe to The Last Romantic"
    style="border: 1px solid var(--ink); background: var(--paper); max-width: 480px;"
    frameborder="0"
    scrolling="no"
    loading="lazy"
  ></iframe>
</aside>

<style>
  .subscribe {
    padding: var(--s-12) 0;
    border-top: var(--rule-heavy) solid var(--ink);
    border-bottom: var(--rule-heavy) solid var(--ink);
    margin: var(--s-16) 0;
  }
  .subscribe--card {
    background: var(--paper-deep);
    padding: var(--s-12) var(--s-8);
    border: 1px solid var(--ink);
    border-radius: 0;
  }
  .subscribe__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 var(--s-3);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .subscribe__lede {
    color: var(--ink-soft);
    font-style: italic;
    margin-bottom: var(--s-6);
    max-width: 36rem;
    font-size: var(--fs-lead);
  }
</style>
