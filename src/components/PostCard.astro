---
import SeriesBadge from './SeriesBadge.astro';

interface Props {
  href: string;
  title: string;
  subtitle?: string;
  series: 'memoir' | 'bourdainism' | 'four-cs' | 'essays' | 'standalone';
  publishedAt: Date;
  wordcount?: number;
  coverImage?: string;
  coverAlt?: string;
}

const {
  href,
  title,
  subtitle,
  series,
  publishedAt,
  wordcount,
  coverImage,
  coverAlt = '',
} = Astro.props;

const date = publishedAt.toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC',
});
const minutes = wordcount ? Math.max(1, Math.round(wordcount / 220)) : null;
---

<article class:list={['card', { 'card--no-image': !coverImage }]}>
  <div class="card__text">
    <div class="card__meta">
      <SeriesBadge series={series} size="sm" />
      <span class="card__dot">·</span>
      <time>{date}</time>
      {minutes && <><span class="card__dot">·</span><span>{minutes} min</span></>}
    </div>
    <h2 class="card__title">
      <a href={href}>{title}</a>
    </h2>
    {subtitle && <p class="card__subtitle">{subtitle}</p>}
  </div>
  {coverImage && (
    <a href={href} class="card__media" tabindex="-1" aria-hidden="true">
      <img src={coverImage} alt={coverAlt} loading="lazy" />
    </a>
  )}
</article>

<style>
  .card {
    padding: var(--s-6) 0;
    border-bottom: 1px solid var(--ink);
    display: grid;
    grid-template-columns: 1fr 5.5rem;
    gap: var(--s-6);
    align-items: center;
  }
  .card--no-image {
    grid-template-columns: 1fr;
  }
  .card:last-child { border-bottom: none; }

  .card__media {
    display: block;
    overflow: hidden;
    width: 5.5rem;
    height: 5.5rem;
    border: 1px solid var(--ink);
    background: var(--paper-deep);
    flex-shrink: 0;
  }
  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .card:hover .card__media img { transform: scale(1.04); }

  .card__text {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    min-width: 0;
  }
  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--font-ui);
    font-size: var(--fs-caption);
    color: var(--ink-soft);
    letter-spacing: 0.06em;
  }
  .card__dot { opacity: 0.4; }
  .card__title {
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    margin: 0;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
  }
  .card__title a {
    color: var(--ink);
    text-decoration: none;
    background-image: linear-gradient(var(--crimson), var(--crimson));
    background-size: 0 2px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition: background-size 200ms;
  }
  .card__title a:hover { background-size: 100% 2px; }
  .card__subtitle {
    color: var(--ink-soft);
    font-style: italic;
    font-size: 1rem;
    margin: 0;
    max-width: 42rem;
    line-height: 1.4;
  }

  @media (max-width: 540px) {
    .card { grid-template-columns: 1fr 4rem; gap: var(--s-4); }
    .card__media { width: 4rem; height: 4rem; }
  }
</style>
