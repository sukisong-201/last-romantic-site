---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Artwork" description="Artwork — coming soon.">
  <section class="container measure artwork">
    <p class="kicker">Artwork</p>
    <h1 class="artwork__title">Coming soon.</h1>
    <p class="artwork__lede">
      <em>The visual half of the publication is in progress.</em>
    </p>
  </section>
</BaseLayout>

<style>
  .artwork { padding: var(--s-24) var(--s-6); text-align: center; }
  .artwork__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: var(--s-3) 0 var(--s-6);
  }
  .artwork__lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    color: var(--ink-soft);
    margin: 0 auto;
    max-width: 32rem;
    line-height: 1.4;
  }
</style>
