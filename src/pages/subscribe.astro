---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Subscribe" description="Subscribe to The Last Romantic.">
  <section class="container measure subscribe">
    <p class="kicker">The Dispatch</p>
    <h1 class="subscribe__title">Subscribe.</h1>

    <div class="subscribe__placeholder">
      <p class="placeholder__note">
        ✏️ <strong>Suki, write a one-or-two-line pitch here.</strong>
        What does the reader get? When does it land? What's it not? The voice is the value.
      </p>
    </div>

    <iframe
      src="https://champagnesuki.substack.com/embed"
      width="100%"
      height="320"
      title="Subscribe to The Last Romantic"
      style="border: 1px solid var(--ink); background: var(--paper); max-width: 540px; margin: var(--s-8) 0;"
      frameborder="0"
      scrolling="no"
    ></iframe>

    <p class="fine">
      Email and management run through Substack. By subscribing, you agree to their
      <a href="https://substack.com/privacy" rel="noopener">privacy policy</a> and
      <a href="https://substack.com/tos" rel="noopener">terms</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .subscribe { padding: var(--s-16) var(--s-6); }
  .subscribe__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: var(--s-3) 0 var(--s-8);
  }
  .subscribe__placeholder {
    border: 1px dashed var(--ink-soft);
    padding: var(--s-8);
    background: var(--paper-deep);
    margin: var(--s-8) 0;
  }
  .placeholder__note {
    margin: 0;
    color: var(--ink-soft);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.5;
  }
  .placeholder__note strong { color: var(--ink); font-style: normal; }
  .fine { font-size: var(--fs-caption); color: var(--smoke); font-family: var(--font-ui); max-width: 36rem; letter-spacing: 0.04em; }
</style>
