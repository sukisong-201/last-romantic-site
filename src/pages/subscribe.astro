---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Subscribe" description="Subscribe to The Last Romantic — memoir, travel, and the four C's. By Suki Song.">
  <section class="container measure subscribe">
    <p class="kicker">The Dispatch</p>
    <h1 class="subscribe__title">Subscribe.</h1>

    <p class="subscribe__pitch">
      My writing in your inbox — <em>memoir, travel, and the four C&rsquo;s.</em>
      It lands when I have something to say. No cadence promises. No lifestyle content.
      No hot takes. Free for now; paid tier comes later, when there&rsquo;s something worth charging for.
    </p>

    <iframe
      src="https://champagnesuki.substack.com/embed"
      width="100%"
      height="320"
      title="Subscribe to The Last Romantic"
      style="border: 1px solid var(--ink); background: var(--paper); max-width: 540px; margin: var(--s-8) 0;"
      frameborder="0"
      scrolling="no"
    ></iframe>

    <p class="fine">
      Email and management run through Substack. By subscribing, you agree to their
      <a href="https://substack.com/privacy" rel="noopener">privacy policy</a> and
      <a href="https://substack.com/tos" rel="noopener">terms</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .subscribe { padding: var(--s-16) var(--s-6); }
  .subscribe__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: var(--s-3) 0 var(--s-8);
  }
  .subscribe__pitch {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    font-style: italic;
    color: var(--ink);
    line-height: 1.4;
    margin: 0 0 var(--s-4);
    max-width: 38rem;
  }
  .subscribe__pitch em {
    font-style: normal;
    font-weight: 600;
  }
  .fine { font-size: var(--fs-caption); color: var(--smoke); font-family: var(--font-ui); max-width: 36rem; letter-spacing: 0.04em; }
</style>
